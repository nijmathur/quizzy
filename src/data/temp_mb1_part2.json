{"id":"mb1-new-295","subject":"math","level":"MB1","gradeRange":"Grades K-3","topic":"Fractions","question":"A bar has 6 equal parts. 4 are shaded. What fraction is shaded?","options":["1/3","1/2","2/3","4/10"],"correctIndex":2,"explanation":"4 out of 6 = 4/6 = 2/3."},
{"id":"mb1-new-296","subject":"math","level":"MB1","gradeRange":"Grades K-3","topic":"Fractions","question":"A class has 12 students. 6 have pencils. What fraction have pencils?","options":["1/4","1/3","1/6","1/2"],"correctIndex":3,"explanation":"6 out of 12 = 6/12 = 1/2."},
{"id":"mb1-new-297","subject":"math","level":"MB1","gradeRange":"Grades K-3","topic":"Fractions","question":"Which number is the denominator in 5/8?","options":["5","3","13","8"],"correctIndex":3,"explanation":"The denominator is the bottom number. In 5/8, the denominator is 8."},
{"id":"mb1-new-298","subject":"math","level":"MB1","gradeRange":"Grades K-3","topic":"Fractions","question":"A circle is divided into 4 equal parts and 3 are colored. What fraction is NOT colored?","options":["3/4","2/4","1/4","0/4"],"correctIndex":2,"explanation":"4 - 3 = 1 part NOT colored out of 4 = 1/4."},
{"id":"mb1-new-299","subject":"math","level":"MB1","gradeRange":"Grades K-3","topic":"Fractions","question":"Which fraction is closest to one whole: 1/4, 1/2, or 3/4?","options":["1/4","1/2","3/4","All equal"],"correctIndex":2,"explanation":"3/4 is closest to one whole (4/4) because 3/4 > 1/2 > 1/4."},
{"id":"mb1-new-300","subject":"math","level":"MB1","gradeRange":"Grades K-3","topic":"Fractions","question":"A bag has 5 red balls and 5 blue balls. What fraction of the balls are red?","options":["1/5","2/5","1/10","1/2"],"correctIndex":3,"explanation":"5 red out of 10 total = 5/10 = 1/2."}
